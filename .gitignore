# ── Dataset ───────────────────────────────────────────────────────────────────
# Large audio dataset (~750 MB) — obtain separately
MLPC2026_dataset_development/

# ── Trained models ────────────────────────────────────────────────────────────
# Binary model artefacts — regenerate with main.py
knn_models/
rf_models/

# ── Generated metrics ─────────────────────────────────────────────────────────
# Per-run CSVs are regenerated on each training run.
# *_experiment_log.csv files are kept — they are the human-readable experiment summaries.
knn_metrics/
rf_metrics/

# ── Fitted preprocessors ──────────────────────────────────────────────────────
# Binary joblib files — regenerate by calling fit_and_save_* in main.py.
# mi_scores.json is kept as it is a small, readable artefact.
sed/data/*.joblib

